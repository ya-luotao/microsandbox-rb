#!/usr/bin/env ruby
# frozen_string_literal: true

require "microsandbox"
require "irb"

# Drop into an IRB session with the gem loaded:
#
#   bin/console
#   >> Microsandbox.version
#   >> Microsandbox::Sandbox.create("demo", image: "alpine") { |sb| sb.exec("uname", ["-a"]).stdout }
IRB.start(__FILE__)
